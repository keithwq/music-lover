{
  "name": "music-learning-app",
  "version": "1.0.0",
  "description": "音乐学习应用 - 互动式音乐理论教学平台",
  "author": {
    "name": "Developer",
    "email": "dev@example.com"
  },
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "cf-build": "opennextjs-cloudflare build",
    "cf-deploy": "opennextjs-cloudflare build && wrangler deploy",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && cross-env NODE_ENV=development electron electron/main.js\"",
    "electron:build": "next build && cross-env NODE_ENV=production electron-builder",
    "test": "jest",
    "test:watch": "jest --watch",
    "cypress": "cypress open"
  },
  "build": {
    "appId": "com.music.learning.app",
    "productName": "音乐学习应用",
    "files": [
      "electron/**/*",
      "out/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "directories": {
      "buildResources": "resources",
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": []
    },
    "linux": {
      "target": []
    }
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "@supabase/auth-helpers-nextjs": "^0.10.0",
    "@supabase/auth-helpers-react": "^0.5.0",
    "@supabase/supabase-js": "^2.49.4",
    "bcrypt": "^5.1.1",
    "cookie": "^1.0.2",
    "docx": "^9.6.1",
    "jsonwebtoken": "^9.0.2",
    "next": "^16.2.4",
    "prisma": "^6.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tone": "^15.0.4"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.4",
    "@tailwindcss/postcss": "^4.1.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie": "^0.6.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^20.17.30",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "cypress": "^14.3.0",
    "electron": "^35.1.5",
    "electron-builder": "^26.0.12",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "wait-on": "^8.0.3",
    "wrangler": "^4.85.0"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}